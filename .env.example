# Database
DATABASE_URL="postgresql://user:password@localhost:5432/crm_db"

# JWT (must be 32+ characters for production)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long"

# Node Environment
NODE_ENV="development"

# Feature Flags (optional - toggle modules on/off)
NEXT_PUBLIC_INTEGRATIONS_ENABLED=false
NEXT_PUBLIC_PROJECTS_ENABLED=true
NEXT_PUBLIC_VOC_ENABLED=true
NEXT_PUBLIC_SERVICES_ENABLED=true

# Email Service (Resend) - optional for email campaigns
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"
